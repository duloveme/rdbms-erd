{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: debug full stack (Chrome)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/playground",
            "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
            "runtimeArgs": ["--inspect"],
            "skipFiles": ["<node_internals>/**"],
            "serverReadyAction": {
                "action": "debugWithChrome",
                "killOnServerStop": true,
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "webRoot": "${workspaceFolder}/apps/playground"
            }
        }
    ]
}
